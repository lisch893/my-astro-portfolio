<script>
  /*const hero = document.querySelector<HTMLElement>(".hero");
  const dots = document.querySelector<HTMLElement>(".dots");

  if (hero && dots) {
    hero.addEventListener("mousemove", (e: MouseEvent) => {
      dots.style.maskImage = `radial-gradient(circle 200px at ${e.clientX}px ${e.clientY}px, transparent 0%, black 100%)`;
    });
  }*/

  const video = document.getElementById("hero-bg-video") as HTMLVideoElement;
  const btn = document.getElementById("pause-bg-video-btn")!;
  const icon = document.getElementById("pause-icon")!;

  btn.addEventListener("click", () => {
    if (video.paused) {
      video.play();
      icon.setAttribute("icon", "mdi:pause");
    } else {
      video.pause();
      icon.setAttribute("icon", "mdi:play");
    }
  });
</script>
