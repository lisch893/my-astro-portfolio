---
import Layout from "../layouts/Layout.astro";
import AboutSection from "../components/AboutSection.astro";
import SkillsSection from "../components/SkillsSection.astro";
import ProjectsSection from "../components/ProjectsSection.astro";
import BlogSection from "../components/BlogSection.astro";
---

<Layout>
  <div class="hero content-center h-dvh bg-white">
    <div
      class="hero-content m-5 rounded-xl bg-green-900 h-19/20 z-20 flex items-end flex-wrap"
    >
      <video
        id="hero-bg-video"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
        src="/forest-top.mp4"
        class="rounded-xl h-full w-full object-cover brightness-65"></video>
      <button
        id="pause-bg-video-btn"
        onclick="pauseVid()"
        type="button"
        class="absolute right-10 bottom-10 text-green-900 p-2 rounded-full bg-white"
        ><iconify-icon id="pause-icon" icon="mdi:pause" class="text-3xl block"
        ></iconify-icon></button
      >
      <div class="p-10 absolute">
        <h1
          class="text-6xl font-semibold tracking-tight leading-normal text-balance text-white pb-5 inline-block w-4/5"
        >
          I am learning React, Astro and Tailwind!
        </h1>
        <p class="font-semibold text-3xl text-white pb-7 font-mono">
          Frontend Development
        </p>
        <div class="grid grid-cols-3 gap-5 w-full">
          <a
            href="#"
            class="text-white px-7 py-5 bg-green-950/30 hover:bg-green-950/60 transition rounded-xl relative group"
          >
            <h2 class="font-semibold text-xl pb-2">Titel menu</h2>
            <p class="font-mono w-3/4">Description of this menu point</p>
            <iconify-icon
              icon="nrk:arrow-right-long"
              class="absolute bottom-4 right-4 text-xl transition-transform group-hover:translate-x-1 duration-400 w-15px hover:w-20px"
            ></iconify-icon>
          </a>
          <a
            href="#"
            class="text-white px-7 py-5 bg-green-950/30 hover:bg-green-950/60 transition rounded-xl relative group"
          >
            <h2 class="font-semibold text-xl pb-2">Titel menu</h2>
            <p class="font-mono w-3/4">Description of this menu point</p>
            <iconify-icon
              icon="nrk:arrow-right-long"
              class="absolute bottom-4 right-4 text-xl transition-transform group-hover:translate-x-1 duration-400 w-15px hover:w-20px"
            ></iconify-icon>
          </a>
          <a
            href="#"
            class="text-white px-7 py-5 bg-green-950/30 hover:bg-green-950/60 transition rounded-xl relative group"
          >
            <h2 class="font-semibold text-xl pb-2">Titel menu</h2>
            <p class="font-mono w-3/4">Description of this menu point</p>
            <iconify-icon
              icon="nrk:arrow-right-long"
              class="absolute bottom-4 right-4 text-xl transition-transform group-hover:translate-x-1 duration-400 w-15px hover:w-20px"
            ></iconify-icon>
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>

<AboutSection />
<SkillsSection />
<ProjectsSection />
<BlogSection />

<style>
  .hero,
  .hero-content {
    position: relative;
  }

  #pause-bg-video-btn {
    cursor: pointer;
  }
